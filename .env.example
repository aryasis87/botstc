# ──────────────────────────────────────────────────────────────
# stcvps backend — TEMPLATE environment variables
# Cara pakai:  cp .env.example .env   lalu edit nilai di bawah.
# Tanda WAJIB = harus diisi.  (opsional) = boleh dikosongkan.
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3001

# CORS — domain frontend produksi (comma-separated, tanpa trailing slash)  [WAJIB]
CORS_ORIGINS=https://stcautotrade.id,https://www.stcautotrade.id

# ── Supabase ──  (ambil dari Dashboard > Settings > API)
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co              # [WAJIB] Project URL
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_DISINI    # [WAJIB] service_role secret

# ── JWT ──  [WAJIB] generate dengan:  openssl rand -hex 32
JWT_SECRET=PASTE_HASIL_openssl_rand_hex_32_DISINI

# ── Firebase FCM ──  pilih SALAH SATU cara (opsional, untuk push notif)
#  (A) upload firebase-service-account.json ke folder project, lalu:
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
#  (B) atau inline (komentari baris A di atas, isi 3 baris ini):
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── SMTP ──  (opsional, untuk broadcast email admin)
#
# ⚠️ KNOWN ISSUE (dicatat 2026-06-13) — fitur email DITUNDA:
#   VPS produksi (103.187.147.153) MEMBLOKIR semua port SMTP keluar
#   (25 / 465 / 587 → semua timeout). Akibatnya kirim via SMTP standar gagal
#   dengan error nodemailer "Connection timeout" (BUKAN password salah).
#   Titan Mail (smtp.titan.email) sendiri benar; temboknya di firewall provider.
#
# CARA MEMPERBAIKI nanti (urut dari termudah):
#   1. Cek port 2525 (port SMTP alternatif, sering tidak diblok):
#        timeout 8 bash -c "echo > /dev/tcp/smtp-relay.brevo.com/2525" && echo OPEN
#      Kalau OPEN → daftar Brevo (gratis 300/hari), set:
#        SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=2525
#        SMTP_USER/PASS = kredensial SMTP Brevo  → TANPA ubah kode.
#   2. Kalau 2525 juga blok → pakai Email API HTTPS port 443 (Brevo/Resend);
#      perlu ubah src/mail/mail.service.ts dari nodemailer ke HTTP API.
#   3. Atau minta provider VPS unblock port 465/587 outbound (buka tiket).
#   Verifikasi domain (SPF/DKIM) di provider agar tidak masuk spam.
#
# Konfigurasi Titan (tersimpan tapi belum jalan karena blokir di atas):
SMTP_HOST=smtp.titan.email
SMTP_PORT=465                          # 465=SSL, 587=STARTTLS, 2525=relay alternatif
SMTP_USER=support@stcautotrade.id
SMTP_PASS=                             # password mailbox (bukan password registrar)
MAIL_FROM=STC AutoTrade <support@stcautotrade.id>

# ── Telegram webhook ──  (opsional)
TELEGRAM_WEBHOOK_API_KEY=

# ── Stockity ──  (opsional)
STOCKITY_REFERRAL=
# Isi hanya jika IP VPS diblok Stockity (lihat DEPLOY.md):
LOGIN_PROXY=
LOGIN_PROXY_STICKY_RANGE=
